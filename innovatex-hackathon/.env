# Database — Supabase managed PostgreSQL (Path B)
# Supabase's direct endpoint (db.<ref>.supabase.co) is IPv6-ONLY since 2024.
# WSL2 here has no IPv6 egress -> direct endpoint is unreachable.
# Use the Shared Pooler (Supavisor) on pooler.supabase.com (IPv4) instead.
# Project region: us-east-2  |  pooler shard: aws-1-  |  user: postgres.<ref>
# Session mode (port 5432) — for Alembic migrations / DDL (long-lived session):
DATABASE_URL=postgresql+psycopg://postgres.asgofjauortyigsoliii:evaluxinnovatex@aws-1-us-east-2.pooler.supabase.com:5432/postgres
# Transaction mode (port 6543) — for FastAPI runtime (many short-lived connections):
# NOTE: transaction mode does NOT support prepared statements (set prepare_threshold=None / no prepared stmts).
DATABASE_URL_POOLER=postgresql+psycopg://postgres.asgofjauortyigsoliii:evaluxinnovatex@aws-1-us-east-2.pooler.supabase.com:6543/postgres
# Legacy Docker vars kept for reference, not used with Path B:
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres
# POSTGRES_DB=diagnostico
# POSTGRES_HOST=postgres
# POSTGRES_PORT=5432

