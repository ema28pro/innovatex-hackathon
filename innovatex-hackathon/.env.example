# Database — Supabase managed PostgreSQL (Path B)
# Direct connection (for Alembic DDL / migrations):
DATABASE_URL=postgresql+psycopg://postgres:<DB_PASSWORD>@db.<REF>.supabase.co:5432/postgres
# Pooler connection (for FastAPI runtime — PgBouncer on port 6543):
DATABASE_URL_POOLER=postgresql+psycopg://postgres.<REF>:<DB_PASSWORD>@aws-0-<REGION>.pooler.supabase.co:6543/postgres

# Supabase Auth
SUPABASE_URL=https://<REF>.supabase.co
SUPABASE_ANON_KEY=<your-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>
SUPABASE_JWKS_URL=https://<REF>.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_JWT_SECRET=

# Frontend (Vite env vars - prefixed with VITE_)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# CORS
CORS_ORIGINS=http://localhost

# AI (placeholder for later phases)
AI_PROVIDER=openai
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
