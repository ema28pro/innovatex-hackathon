  "security_requirements": {
    "jwt": {
      "type": "Supabase JWT",
      "storage": "access + refresh in memory/httpOnly",
      "expiration": "short-lived access, longer refresh",
      "interceptor": "Axios auto-refresh on 401"
    },
    "transport": "HTTPS mandatory (nginx 80→443 redirect)",
    "cors": "Restricted to configured domains (no wildcard in prod)",
    "rate_limiting": "slowapi middleware, strict on auth and AI routes",
    "tenancy": "Middleware resolves company_id from JWT; all queries scoped via TenantQuery helper; cross-tenant access returns 404 (not 403 to prevent enumeration)",
    "input_validation": "Pydantic Field constraints on all schemas (length, enums, regex for NIT/email)",
    "sanitization": "No dangerouslySetInnerHTML on user data; SSRF rejected on user-supplied URLs",
    "secrets": "All via .env / pydantic-settings; .env.example files provided; no secrets in repo",
    "headers": "Security headers in nginx.conf (HSTS, X-Content-Type, X-Frame, CSP)",
    "owasp_target": "No High findings on ZAP/Burp scan"
  },

