  "scoring_logic": {
    "per_question": {
      "yes": 1.0,
      "partial": 0.5,
      "no": 0.0,
      "na": "excluded"
    },
    "section_score": "sum(answered_non_na_scores) / count(answered_non_na_questions)",
    "global_score": "simple_average_across_all_sections (equal weight)",
    "compliance_percentage": "global_score × 100",
    "maturity_matrix": {
      "0-20": {"label": "No existe", "min": 0, "max": 20},
      "21-40": {"label": "Inicial", "min": 21, "max": 40},
      "41-60": {"label": "Parcialmente implementado", "min": 41, "max": 60},
      "61-80": {"label": "Implementado", "min": 61, "max": 80},
      "81-100": {"label": "Optimizado", "min": 81, "max": 100}
    },
    "trigger": "computed on assessment completion (status=completed), not during in-progress"
  },

  "data_model": {
    "tables": [
      {
        "name": "users",
        "columns": "id (PK), email (UQ), name, created_at, updated_at",
        "notes": "Supabase Auth provides the JWT; this table mirrors the Supabase user for app-level data"
      },
      {
        "name": "companies",
        "columns": "id (PK), name, nit, sector, size, contact_email, employee_count, db_count, data_types_processed, created_at",
        "notes": "Multi-tenant root entity"
      },
      {
        "name": "user_company_roles",
        "columns": "id (PK), user_id (FK→users), company_id (FK→companies), role (enum: admin/auditor/reader)",
        "notes": "Tenant-role join table"
      },
      {
        "name": "assessments",
        "columns": "id (PK), company_id (FK→companies), created_by (FK→users), status (in_progress/completed), overall_score, completed_at, created_at, updated_at"
      },
      {
        "name": "assessment_answers",
        "columns": "id (PK), assessment_id (FK→assessments), section_id (FK→sections), question_id (FK→questions), answer (yes/no/partial/na), notes",
        "notes": "Upsert by composite (assessment_id, question_id)"
      },
      {
        "name": "sections",
        "columns": "id (PK), name, order, is_optional",
        "notes": "10 fixed sections seeded"
      },
      {
        "name": "questions",
        "columns": "id (PK), section_id (FK→sections), text, order, legal_reference, ai_explanation_prompt",
        "notes": "43 questions seeded per questionnaire design"
      },
      {
        "name": "scores",
        "columns": "id (PK), assessment_id (FK→assessments), section_id (FK→sections), score, max_score, percentage",
        "notes": "Recomputed and replaced on assessment completion"
      },
      {
        "name": "recommendations",
        "columns": "id (PK), assessment_id (FK→assessments), section_id (FK→sections), ai_generated_text, priority (high/medium/low)"
      },
      {
        "name": "action_items",
        "columns": "id (PK), recommendation_id (FK→recommendations), assessment_id (FK→assessments), status (pending/in_progress/completed), assigned_to (FK→users), notes",
        "notes": "No due dates in MVP"
      },
      {
        "name": "share_links",
        "columns": "id (PK), assessment_id (FK→assessments), token (UQ, UUID), expires_at, created_by (FK→users)"
      }
    ],
    "total_tables": 11,
    "indexes": ["uix_user_email", "uix_share_token", "FK indexes on all foreign keys"],
    "delete_strategy": "RESTRICT (soft cascade) — preserve audit trail"
  },

